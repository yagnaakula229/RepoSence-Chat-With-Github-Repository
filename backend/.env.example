# Example environment variables for RepoSense AI backend
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-3.5-turbo
HUGGINGFACEHUB_API_TOKEN=YOUR_HUGGINGFACE_API_TOKEN  # optional, used when OPENAI_API_KEY is not set
GITHUB_TOKEN=YOUR_GITHUB_TOKEN  # optional, improves rate limits for private/public repos